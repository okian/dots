#!/usr/bin/env bash
# Seed the tldr (tealdeer) page cache once so `tldr <cmd>` and the television
# `tldr` channel work offline immediately. tealdeer keeps it fresh afterwards
# (auto_update in ~/.config/tealdeer/config.toml). Degrades gracefully.
set -euo pipefail

for p in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; do
  [ -x "$p" ] && eval "$("$p" shellenv)" && break
done

if ! command -v tldr >/dev/null 2>&1; then
  echo "tldr not found; skipping cache seed"
  exit 0
fi

echo "==> Seeding tldr cache"
tldr --update || echo "    tldr --update failed (offline?); will retry on first use"
echo "==> tldr done"
