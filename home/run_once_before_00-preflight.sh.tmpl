#!/usr/bin/env bash
# Preflight: ensure the bare minimum compilers/tools exist before Homebrew.
set -euo pipefail

SUDO=""
if [ "$(id -u)" -ne 0 ]; then SUDO="sudo"; fi

{{ if .isMac -}}
echo "==> [preflight] macOS — ensuring Xcode Command Line Tools"
if ! xcode-select -p >/dev/null 2>&1; then
  xcode-select --install || true
  echo "    A CLT install dialog may have opened. Re-run once it finishes if this fails."
  # Wait for CLT to become available (non-interactive best effort).
  until xcode-select -p >/dev/null 2>&1; do sleep 5; done
fi
{{ else if .isLinux -}}
echo "==> [preflight] Linux — installing build essentials"
if command -v apt-get >/dev/null 2>&1; then
  export DEBIAN_FRONTEND=noninteractive
  $SUDO apt-get update -y
  $SUDO apt-get install -y build-essential procps curl file git ca-certificates locales
elif command -v dnf >/dev/null 2>&1; then
  $SUDO dnf groupinstall -y "Development Tools"
  $SUDO dnf install -y curl file git procps-ng
elif command -v pacman >/dev/null 2>&1; then
  $SUDO pacman -Sy --noconfirm base-devel curl file git
fi
{{ end -}}
echo "==> [preflight] done"
