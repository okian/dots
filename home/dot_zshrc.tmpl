{{- $brew := "/home/linuxbrew/.linuxbrew" -}}
{{- if .isMac -}}{{- if eq .chezmoi.arch "arm64" -}}{{- $brew = "/opt/homebrew" -}}{{- else -}}{{- $brew = "/usr/local" -}}{{- end -}}{{- end -}}
# .zshrc — fallback shell (default is nushell). Managed by chezmoi.

# Homebrew
[ -x "{{ $brew }}/bin/brew" ] && eval "$({{ $brew }}/bin/brew shellenv)"

# PATH
export PATH="$HOME/.swiftly/bin:$HOME/.cargo/bin:$HOME/.local/bin:$PATH"
export EDITOR=nvim VISUAL=nvim

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS INC_APPEND_HISTORY

# Completions + vi mode
autoload -Uz compinit && compinit
bindkey -v
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# fzf: use fd, show hidden (minus .git)
if command -v fd >/dev/null; then
  export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
  export FZF_DEFAULT_OPTS='--height 40% --layout reverse --border'
fi

# Aliases
alias ll='eza -la --icons --group-directories-first 2>/dev/null || ls -la'
alias lt='eza --tree --level=2 --icons'
alias g='git' lg='lazygit' v='nvim' vim='nvim' cat='bat'
alias nu='nu'   # drop into nushell anytime
# Container muscle-memory: docker -> podman
alias docker='podman' docker-compose='podman-compose' dc='podman-compose'

# Integrations
command -v starship >/dev/null && eval "$(starship init zsh)"
command -v zoxide   >/dev/null && eval "$(zoxide init zsh)"
command -v direnv   >/dev/null && eval "$(direnv hook zsh)"
command -v atuin    >/dev/null && eval "$(atuin init zsh)"
command -v carapace >/dev/null && { export CARAPACE_BRIDGES='zsh,fish,bash'; source <(carapace _carapace zsh); }
[ -f "$(brew --prefix 2>/dev/null)/opt/fzf/shell/key-bindings.zsh" ] && \
  source "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
[ -f "$(brew --prefix 2>/dev/null)/opt/fzf/shell/completion.zsh" ] && \
  source "$(brew --prefix)/opt/fzf/shell/completion.zsh"

# zsh-autosuggestions + fast-syntax-highlighting (load highlighting LAST)
_brew_prefix="$(brew --prefix 2>/dev/null)"
[ -f "$_brew_prefix/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ] && \
  source "$_brew_prefix/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
[ -f "$_brew_prefix/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ] && \
  source "$_brew_prefix/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
unset _brew_prefix
