;;; config.el -*- lexical-binding: t; -*-
;; Personal Doom config. Managed by chezmoi.

(setq user-full-name {{ .name | quote }}
      user-mail-address {{ .email | quote }})

;; ── Fonts ────────────────────────────────────────────────────────────────
;; JetBrainsMono Nerd Font (installed by provisioning, both OSes).
(setq doom-font     (font-spec :family "JetBrainsMono Nerd Font" :size 14)
      doom-big-font (font-spec :family "JetBrainsMono Nerd Font" :size 20))
(setq-default line-spacing 0.1)

;; ── Theme: Catppuccin Mocha ────────────────────────────────────────────────
;; Matches WezTerm / nushell / FZF / tmux / Neovim. catppuccin-flavor must be
;; set before the theme loads (Doom loads doom-theme after this file).
(setq catppuccin-flavor 'mocha
      doom-theme 'catppuccin)

;; Subtle frame transparency to echo the WezTerm window (opacity 0.97).
;; Ignored gracefully on builds without alpha-background support.
(add-to-list 'default-frame-alist '(alpha-background . 97))

;; ── Editor UX ───────────────────────────────────────────────────────────────
(setq display-line-numbers-type 'relative)
(setq which-key-idle-delay 0.4)

;; The login shell is nushell, which isn't POSIX — Emacs spawns child processes
;; (diff-hl, TRAMP, magit, …) via a POSIX shell, so point those at bash while
;; keeping the interactive terminals on nushell.
(when (executable-find "bash")
  (setq shell-file-name (executable-find "bash")))
(setq-default vterm-shell (executable-find "nu")
              explicit-shell-file-name (executable-find "nu"))

;; Quieter modeline: drop the encoding/EOL indicator clutter.
(after! doom-modeline
  (setq doom-modeline-buffer-encoding nil))

;; ── Projects ────────────────────────────────────────────────────────────────
(setq projectile-project-search-path '("~/projects/"))

(after! lsp-mode
  (setq lsp-idle-delay 0.5))
