{{- $brew := "/home/linuxbrew/.linuxbrew" -}}
{{- if .isMac -}}{{- if eq .chezmoi.arch "arm64" -}}{{- $brew = "/opt/homebrew" -}}{{- else -}}{{- $brew = "/usr/local" -}}{{- end -}}{{- end -}}
# env.nu — loaded before config.nu. Managed by chezmoi.

# PATH (front to back precedence).
$env.PATH = ($env.PATH
  | split row (char esep)
  | prepend ($env.HOME | path join '.local/bin')
  | prepend ($env.HOME | path join 'bins')
  | prepend ($env.HOME | path join 'go/bin')
  | prepend ($env.HOME | path join '.cargo/bin')
  | prepend ($env.HOME | path join '.swiftly/bin')
  | prepend '{{ $brew }}/bin'
  | prepend '{{ $brew }}/sbin'
  | uniq)

# Neovim is THE editor everywhere (shell, git, k8s, fc, etc.).
$env.EDITOR = 'nvim'
$env.VISUAL = 'nvim'
$env.GIT_EDITOR = 'nvim'
$env.KUBE_EDITOR = 'nvim'
$env.HOMEBREW_PREFIX = '{{ $brew }}'

# Pretty, syntax-highlighted man pages via bat.
if (which bat | is-not-empty) {
  $env.MANPAGER = "sh -c 'col -bx | bat -l man -p'"
  $env.MANROFFOPT = '-c'
}

# Tool integrations (starship, zoxide, carapace, television — the last wires
# Ctrl-T autocomplete + Ctrl-R history) are PRE-generated into nushell's vendor
# autoload dir by run_after_25-shell-integrations on `chezmoi apply`, and
# auto-sourced on startup. Doing it there (not here) means an interactive shell
# spawns nothing — a noticeably faster prompt. We only set the runtime env
# carapace needs to bridge other shells' completers.
$env.CARAPACE_BRIDGES = 'zsh,fish,bash'
