#!/usr/bin/env bash
# git-identities-sync — keep per-entity git config in sync with ~/projects.
#
# Each top-level directory under ~/projects is an "entity" (work, personal, NGO…)
# that can carry its own git identity. This regenerates
#   ~/.config/git/conf.d/identities.gitconfig
# with one  includeIf "gitdir:~/projects/<entity>/"  block per entity, each
# pointing at a per-entity  ~/.config/git/conf.d/<entity>.gitconfig  that holds
# its [user] (name/email/signingkey). The global ~/.config/git/config includes
# the generated file last, so a matching entity's identity overrides the global.
#
#   * ~/projects has entity dirs -> those drive the set.
#   * ~/projects empty or absent -> entities are derived from the per-entity
#                                  config files (decrypted from the dotfiles
#                                  repo) and their ~/projects dirs are created.
#   * per-entity files are created only when missing — your edits never get
#     clobbered; removed entities simply drop their includeIf block.
#
# Idempotent, atomic, and quiet unless something actually changes.
# Invoked every apply by run_after_45-git-identities and on demand via
# `dots git-identity sync`.
set -euo pipefail

quiet=0
[ "${1:-}" = "--quiet" ] && quiet=1
log() { [ "$quiet" -eq 1 ] || printf '%s\n' "$*"; }

repos="$HOME/projects"
gitcfg="$HOME/.config/git/config"
confd="$HOME/.config/git/conf.d"
gen="$confd/identities.gitconfig"
mkdir -p "$confd"

# Self-heal: guarantee the global git config includes the generated file. This
# normally ships baked into config.tmpl, but ensuring it here means adding an
# entity works even on a machine whose global config predates the feature.
# Idempotent; targets the file explicitly (not --global) so the relative
# include path resolves against ~/.config/git/ and we never write a stray
# ~/.gitconfig. Silent unless it actually wires the line in.
include_rel="conf.d/identities.gitconfig"
if ! git config --file "$gitcfg" --get-all include.path 2>/dev/null | grep -qxF "$include_rel"; then
  git config --file "$gitcfg" --add include.path "$include_rel"
  log "==> wired '[include] path = $include_rel' into $gitcfg"
fi

# Fallback identity for entities that don't have their own file yet.
global_name="$(git config --global user.name 2>/dev/null || true)"
global_email="$(git config --global user.email 2>/dev/null || true)"

# --- Collect entity names ---------------------------------------------------
entities=()

shopt -s nullglob
repo_dirs=("$repos"/*/)   # trailing slash -> directories only; skips files
shopt -u nullglob

if [ "${#repo_dirs[@]}" -gt 0 ]; then
  for d in "${repo_dirs[@]}"; do
    entities+=("$(basename "$d")")
  done
else
  # Bootstrap: ~/projects empty/absent -> derive entities from per-entity config
  # files and create their project directories.
  shopt -s nullglob
  conf_files=("$confd"/*.gitconfig)
  shopt -u nullglob
  if [ "${#conf_files[@]}" -gt 0 ]; then
    for f in "${conf_files[@]}"; do
      base="$(basename "$f" .gitconfig)"
      [ "$base" = "identities" ] && continue   # the generated file itself
      entities+=("$base")
      if [ ! -d "$repos/$base" ]; then
        mkdir -p "$repos/$base"
        log "==> created $repos/$base"
      fi
    done
  fi
fi

# --- Build the generated include file (sorted, deterministic) ---------------
tmp="$(mktemp "$confd/.identities.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

{
  echo "# Generated by git-identities-sync — DO NOT EDIT."
  echo "# Regenerated on every \`chezmoi apply\` and \`dots git-identity sync\`."
  echo "# One block per entity directory under ~/projects."
  echo
} > "$tmp"

if [ "${#entities[@]}" -gt 0 ]; then
  sorted="$(printf '%s\n' "${entities[@]}" | LC_ALL=C sort -u)"
  while IFS= read -r e; do
    [ -n "$e" ] || continue
    pef="$confd/$e.gitconfig"
    if [ ! -f "$pef" ]; then
      {
        echo "# git identity for \"$e\" — auto-created, safe to edit."
        echo "# Applied to every repo under ~/projects/$e/."
        echo "[user]"
        [ -n "$global_name" ]  && echo "	name = $global_name"
        [ -n "$global_email" ] && echo "	email = $global_email"
      } > "$pef"
      log "==> created default $pef — set its email with: dots git-identity edit $e"
    fi
    {
      echo "[includeIf \"gitdir:~/projects/$e/\"]"
      echo "	path = $e.gitconfig"
    } >> "$tmp"
  done <<< "$sorted"
fi

# --- Install only if changed (atomic mv; stays quiet when nothing moved) ----
if [ ! -f "$gen" ] || ! cmp -s "$tmp" "$gen"; then
  mv "$tmp" "$gen"
  n="${#entities[@]}"
  log "==> updated $gen ($n identit$([ "$n" -eq 1 ] && echo y || echo ies))"
fi
# Any unmoved tmp is cleaned up by the EXIT trap.
