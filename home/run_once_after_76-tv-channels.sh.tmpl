#!/usr/bin/env bash
# Download television's cable channels (files, text, git-*, env, …) so `tv`,
# ff/fcd, the Ctrl-R/Ctrl-T shell bindings and the nvim picker have channels to
# use on a fresh machine. Our own channels are chezmoi-managed and applied first
# (cable/nu-history.toml — fixed for nushell's sqlite history — and cable/tldr.toml);
# `tv update-channels` SKIPS files that already exist, so ours always win.
# Network best-effort: never hard-fails provisioning.
set -euo pipefail

for p in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; do
  [ -x "$p" ] && eval "$("$p" shellenv)" && break
done

if ! command -v tv >/dev/null 2>&1; then
  echo "television (tv) not found; skipping channel download"
  exit 0
fi

echo "==> Downloading television cable channels"
tv update-channels || echo "    tv update-channels failed (offline?); run 'tv update-channels' later"
echo "==> tv channels done"
